					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var json = pm.response.json();",
									"if(json.data){",
									"  pm.collectionVariables.set('adminToken', json.data.accessToken);",
									"  pm.collectionVariables.set('accessToken', json.data.accessToken);",
									"  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
									"}",
									"pm.test('Login OK', function(){ pm.response.to.have.status(200); });"
